                </Ellipse>
            </PartDraw>
            <PartDraw x="0" y="0" width="450" height="450" alpha="153">
                <!-- Leave deliberate clearance around the four cardinal labels. -->
                <Arc centerX="225" centerY="225" width="317" height="317" startAngle="12" endAngle="78">
                    <Stroke color="[CONFIGURATION.radarColor]" thickness="1.5" />
                </Arc>
                <Arc centerX="225" centerY="225" width="317" height="317" startAngle="102" endAngle="168">
                    <Stroke color="[CONFIGURATION.radarColor]" thickness="1.5" />
