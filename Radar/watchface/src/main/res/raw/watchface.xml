    <Scene>
        <!--
          The dial's original outer extent is 204 + 1.5 = 205.5 units.
          Scaling 205.5 to the 225-unit scene radius makes the ring's outer
          edge meet every circular display edge while WFF handles resolution.
        -->
        <Group
            name="edge_fitted_face"
            x="0"
            y="0"
            width="450"
            height="450"
            pivotX="0.5"
            pivotY="0.5"
            scaleX="1.09489"
            scaleY="1.09489">
        <!-- OLED-safe base: every pixel is truly black in ambient mode. -->
        <PartDraw
            name="black_base"
            x="0"
            y="0"
            width="450"
            height="450">
            <Rectangle x="0" y="0" width="450" height="450">
                <Fill color="#FF000000" />
            </Rectangle>
        </PartDraw>

        <!-- A restrained configurable wash gives the active face its instrument glow. -->
        <Group
            name="interactive_dial_glow"
            x="0"
            y="0"
            width="450"
            height="450">
            <Variant
                mode="AMBIENT"
                target="alpha"
                value="0" />
            <PartDraw x="0" y="0" width="450" height="450" alpha="16">
                <Ellipse x="18" y="18" width="414" height="414">
                    <Fill color="[CONFIGURATION.radarColor]" />
