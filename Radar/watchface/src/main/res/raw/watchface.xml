        <Group
            name="dial_labels"
            x="0"
            y="0"
            width="450"
            height="450">
            <Variant
                mode="AMBIENT"
                target="alpha"
                value="255" />

            <PartText x="195" y="39" width="60" height="32">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="23" weight="BOLD" color="[CONFIGURATION.radarColor]">12</Font>
                </Text>
            </PartText>
            <PartText x="379" y="209" width="38" height="32">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="23" weight="BOLD" color="[CONFIGURATION.radarColor]">3</Font>
                </Text>
            </PartText>
            <PartText x="195" y="379" width="60" height="32">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="23" weight="BOLD" color="[CONFIGURATION.radarColor]">6</Font>
                </Text>
            </PartText>
            <PartText x="33" y="209" width="38" height="32">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="23" weight="BOLD" color="[CONFIGURATION.radarColor]">9</Font>
                </Text>
            </PartText>

            <PartText x="198" y="105" width="54" height="28" alpha="230">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="18" weight="BOLD" color="[CONFIGURATION.radarColor]">60</Font>
