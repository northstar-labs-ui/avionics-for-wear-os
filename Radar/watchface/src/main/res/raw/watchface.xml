            <PartDraw x="0" y="0" width="450" height="450" alpha="179">
                <Arc
                    centerX="225"
                    centerY="225"
                    width="239"
                    height="239"
                    startAngle="0"
                    endAngle="360">
                    <Stroke
                        color="[CONFIGURATION.radarColor]"
                        thickness="3"
                        dashIntervals="2.1 10.78"
                        dashPhase="0" />
                </Arc>
            </PartDraw>
            <PartDraw x="0" y="0" width="450" height="450">
                <Line startX="225" startY="103" endX="225" endY="105">
                    <Stroke color="[CONFIGURATION.radarColor]" thickness="3" />
