        <BooleanConfiguration id="alignment_debug">
            <BooleanOption id="TRUE">
                <AnalogClock x="0" y="0" width="450" height="450">
                    <HourHand
                        resource="debug_hour_center_dot"
                        x="222"
                        y="37"
                        width="6"
                        height="188"
                        pivotX="0.5"
                        pivotY="1" />
                    <MinuteHand
                        resource="debug_minute_center_dot"
