                <Line startX="286" startY="119.3" endX="281.5" endY="127.2">
                    <Stroke color="[CONFIGURATION.radarColor]" thickness="3" />
                </Line>
                <Line startX="330.7" startY="164" endX="322.8" endY="168.5">
                    <Stroke color="[CONFIGURATION.radarColor]" thickness="3" />
