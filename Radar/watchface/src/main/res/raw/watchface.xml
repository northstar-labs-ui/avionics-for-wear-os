        <!--
          The sourced vector silhouettes are used as the actual clock hands:
          passenger plane = hours, fighter jet = minutes, beam = seconds.
        -->
        <AnalogClock x="0" y="0" width="450" height="450">
            <!--
              Outer lane: (158.5 + 204) / 2 = 181.25 orbit radius.
              The transformed silhouette is 44 units long tangentially and
              36 units high radially, with visible ring clearance on both sides.
            -->
            <HourHand
                resource="hour_passenger_plane"
                x="201"
                y="21"
                width="48"
                height="204"
                pivotX="0.5"
                pivotY="1"
                tintColor="[CONFIGURATION.radarColor]" />
            <!--
              Next lane inward: (113 + 158.5) / 2 = 135.75 orbit radius.
              The transformed silhouette is 38 units long tangentially and
              22.5 units high radially, clearing the minute tick band as well.
            -->
            <MinuteHand
                resource="minute_fighter_jet"
                x="205"
                y="65"
                width="40"
                height="160"
                pivotX="0.5"
                pivotY="1"
                tintColor="[CONFIGURATION.radarColor]" />
            <SecondHand
                resource="radar_sweep_glow"
                x="218"
                y="22"
                width="14"
                height="203"
                pivotX="0.5"
                pivotY="1"
                tintColor="[CONFIGURATION.radarColor]">
                <Variant mode="AMBIENT" target="alpha" value="0" />
                <Sweep frequency="15" />
            </SecondHand>
            <SecondHand
                resource="radar_sweep"
                x="223"
                y="22"
                width="4"
                height="203"
                pivotX="0.5"
                pivotY="1"
                tintColor="[CONFIGURATION.radarColor]">
                <Variant mode="AMBIENT" target="alpha" value="0" />
                <Sweep frequency="15" />
            </SecondHand>
        </AnalogClock>

