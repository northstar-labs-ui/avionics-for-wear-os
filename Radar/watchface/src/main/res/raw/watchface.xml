                            centerY="225"
                            width="362.5"
                            height="362.5"
                            startAngle="0"
                            endAngle="360">
                            <Stroke color="#1838BDF8" thickness="43.5" />
                        </Arc>
                        <Arc
                            centerX="225"
                            centerY="225"
                            width="271.5"
                            height="271.5"
                            startAngle="0"
                            endAngle="360">
                            <Stroke color="#1822D3A7" thickness="43.5" />
                        </Arc>
                    </PartDraw>
                </Group>
            </BooleanOption>
        </BooleanConfiguration>

        <!-- Radar rings and crosshairs stay sparse enough for always-on display. -->
        <Group
