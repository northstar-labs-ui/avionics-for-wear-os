            </PartDraw>
            <PartDraw x="0" y="0" width="450" height="450" alpha="10">
                <Ellipse x="65" y="65" width="320" height="320">
                    <Fill color="[CONFIGURATION.radarColor]" />
                </Ellipse>
            </PartDraw>
            <PartDraw x="0" y="0" width="450" height="450" alpha="14">
                <Ellipse x="154" y="154" width="142" height="142">
                    <Fill color="[CONFIGURATION.radarColor]" />
                </Ellipse>
            </PartDraw>
        </Group>

        <!--
          Debug lane overlay. The strokes sit just inside the ring centerlines:
          outer/hour lane = 158.5..204, midpoint 181.25;
          inner/minute lane = 113..158.5, midpoint 135.75.
        -->
        <BooleanConfiguration id="alignment_debug">
            <BooleanOption id="TRUE">
                <Group
                    name="alignment_lane_shading"
                    x="0"
                    y="0"
                    width="450"
                    height="450">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <PartDraw x="0" y="0" width="450" height="450">
